# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=notebox
POSTGRES_USER=notebox
POSTGRES_PASSWORD=notebox

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=notebox-files
S3_REGION=us-east-1

# Server
SERVER_PORT=8080
DEMO_MODE_ENABLED=true

# CORS (comma-separated list of allowed origin patterns, * для динамических портов)
CORS_ALLOWED_ORIGINS=http://localhost:*,http://host.docker.internal:*

# Test origin (used by E2E tests with dynamic ports, leave empty for production)
TEST_ORIGIN=

# Nginx
NGINX_PORT=80

# Frontend Base Path (для развёртывания приложения в subpath)
# Примеры:
#   VITE_BASE_PATH=          - для развёртывания в корне (по умолчанию)
#   VITE_BASE_PATH=/notebox  - для развёртывания на /notebox/
#   VITE_BASE_PATH=/app/     - для развёртывания на /app/
# Примечание: слэши добавляются автоматически
VITE_BASE_PATH=
